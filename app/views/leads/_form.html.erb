<div class="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-2xl shadow-slate-200/50">
  <%= form_with model: @lead, class: "space-y-6" do |f| %>
    
    <div class="space-y-2">
      <%= f.label :name, class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.text_field :name, placeholder: "Full Name", 
          class: "w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:bg-white focus:ring-[6px] focus:ring-indigo-500/5 focus:border-indigo-600 outline-none transition-all font-medium" %>
    </div>

    <div class="space-y-2">
      <%= f.label :email, class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.email_field :email, placeholder: "email@company.com", 
          class: "w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:bg-white focus:ring-[6px] focus:ring-indigo-500/5 focus:border-indigo-600 outline-none transition-all font-medium" %>
    </div>

    <div class="space-y-2">
      <%= f.label :status, class: "text-sm font-bold text-slate-700 ml-1" %>
      <div class="relative">
        <%= f.select :status, Lead.statuses.keys.map { |s| [s.humanize, s] }, {}, 
            class: "w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl appearance-none focus:bg-white focus:ring-[6px] focus:ring-indigo-500/5 focus:border-indigo-600 outline-none transition-all font-bold text-slate-700" %>
        <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-slate-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </div>
      </div>
    </div>

    <div class="pt-4">
      <%= f.submit "Save Lead Profile", 
          class: "w-full bg-indigo-600 text-white font-black py-5 rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all active:scale-[0.98] cursor-pointer" %>
    </div>
  <% end %>
</div>