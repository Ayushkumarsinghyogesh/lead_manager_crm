<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-end mb-8">
    <div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight">Analytics Overview</h1>
      <p class="text-slate-500 font-medium">Monitor your sales pipeline performance.</p>
    </div>
    <%= link_to leads_path, class: "group flex items-center gap-2 bg-white border border-slate-200 px-5 py-2.5 rounded-xl font-bold text-slate-700 hover:bg-slate-50 transition-all shadow-sm" do %>
      Manage Leads
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7l5 5m0 0l-5 5m5-5H6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm relative overflow-hidden group">
      <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform">
        <svg class="w-16 h-16 text-indigo-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      </div>
      <p class="text-slate-500 font-bold text-sm uppercase tracking-wider mb-1">Total Pipeline</p>
      <h2 class="text-5xl font-black text-slate-900 leading-none"><%= @total_leads %></h2>
      <div class="mt-4 flex items-center text-emerald-600 text-sm font-bold">
        <span class="bg-emerald-100 px-2 py-0.5 rounded-md mr-2">↑ 12%</span>
        <span class="text-slate-400 font-medium text-xs">vs last month</span>
      </div>
    </div>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm relative overflow-hidden group">
      <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform">
        <svg class="w-16 h-16 text-emerald-600" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
      </div>
      <p class="text-slate-500 font-bold text-sm uppercase tracking-wider mb-1">Conversions</p>
      <h2 class="text-5xl font-black text-emerald-600 leading-none"><%= @converted %></h2>
      <div class="mt-4 flex items-center text-slate-400 text-sm font-medium">
        Active win rate: <span class="text-slate-900 font-bold ml-1">24%</span>
      </div>
    </div>

    <div class="bg-indigo-600 p-8 rounded-[2rem] shadow-xl shadow-indigo-200 flex flex-col justify-center items-center text-center">
      <p class="text-indigo-100 font-bold mb-4">Ready to grow?</p>
      <%= link_to "Add New Lead", new_lead_path, class: "w-full bg-white text-indigo-600 font-black py-4 rounded-2xl hover:bg-indigo-50 transition-all active:scale-[0.98]" %>
    </div>
  </div>
</div>